# ─────────────────────────────────────────────────────────────────────────────
# Document Intelligence Toolkit — Environment Variables Template
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (choose one or both) ────────────────────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT
OPENAI_API_KEY=your_openai_api_key_here

# ── Model Selection ───────────────────────────────────────────────────────────
# Which model to use for summarization and comparison chains.
# Examples: "claude-sonnet-4-6", "gpt-4o", "gpt-4o-mini"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ── Chunking / Token Settings ─────────────────────────────────────────────────
# Maximum tokens per chunk when splitting large documents
CHUNK_SIZE=1500
# Overlap in tokens between consecutive chunks to preserve context
CHUNK_OVERLAP=150
# Token count above which Map-Reduce summarization is used instead of single-pass
MAP_REDUCE_THRESHOLD=6000

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
